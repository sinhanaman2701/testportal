generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  LATEST
  ONGOING
  COMPLETED
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password_hash String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id               Int      @id @default(autoincrement())
  projectName      String
  description      String
  location         String
  
  bedrooms         Int
  bathrooms        Int?
  price            String?
  furnishing       String
  floor            String
  area             String
  
  project_brochure String?
  thumbnailUrl     String?
  locationIframe   String?
  projectStatus    ProjectStatus @default(ONGOING)

  isActive         Boolean  @default(true)
  isArchived       Boolean  @default(false)

  createdBy        Int?
  updatedBy        Int?
  clickCount       Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  communityAmenities CommunityAmenity[]
  propertyAmenities  PropertyAmenity[]
  nearbyPlaces       NearbyPlace[]

  @@index([isArchived])
  @@index([location])
  @@index([createdAt])
}

model CommunityAmenity {
  id         Int      @id @default(autoincrement())
  projectId  Int
  name       String
  imageUrl   String?
  project    Project  @relation(fields: [projectId], references: [id])
}

model PropertyAmenity {
  id         Int      @id @default(autoincrement())
  projectId  Int
  name       String
  iconUrl    String?
  project    Project  @relation(fields: [projectId], references: [id])
}

model NearbyPlace {
  id         Int      @id @default(autoincrement())
  projectId  Int
  category   String   // Hospital, School, etc.
  distanceKm Float
  iconUrl    String?
  project    Project  @relation(fields: [projectId], references: [id])
}
